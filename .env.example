# Required: OpenRouter API key used by server routes
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional but recommended: default model shown/used by backend
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini

# Optional: comma-separated model allowlist enforced by backend
# Example: nvidia/nemotron-3-super-120b-a12b:free,openai/gpt-4o-mini
OPENROUTER_ALLOWED_MODELS=nvidia/nemotron-3-super-120b-a12b:free,qwen/qwen3.6-plus:free,meta-llama/llama-3.3-70b-instruct:free,google/gemma-3-12b-it:free,openai/gpt-oss-20b:free

# Required: Supabase project URL for REST insert endpoint
SUPABASE_URL=https://your-project-ref.supabase.co

# Required: Supabase service role key (server-only secret)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Optional: app URL sent as HTTP-Referer to OpenRouter
APP_URL=http://localhost:3000
